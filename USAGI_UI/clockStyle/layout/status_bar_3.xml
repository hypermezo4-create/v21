<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.statusbar.phone.MiuiPhoneStatusBarView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@id/status_bar"
    android:focusable="false"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:descendantFocusability="afterDescendants"
    android:layout_width="match_parent"
    android:layout_height="@dimen/status_bar_height"
    android:accessibilityPaneTitle="@string/status_bar">
    <com.android.systemui.statusbar.views.BatteryIndicator
        android:id="@id/battery_indicator"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/battery_line_height"
        android:src="@drawable/battery_indicator" />
    <com.android.systemui.statusbar.phone.MiuiHomePrivacyView
        android:layout_gravity="center|end"
        android:orientation="horizontal"
        android:id="@id/home_privacy_container"
        android:paddingTop="@dimen/status_bar_padding_top"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingEnd="@dimen/status_bar_padding_end" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/status_bar_contents"
        android:paddingTop="@dimen/status_bar_padding_top"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="@dimen/status_bar_padding_start"
        android:paddingEnd="@dimen/status_bar_padding_end">
        <LinearLayout
            android:id="@id/phone_status_bar_left_container"
            android:clipChildren="false"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">
            <include layout="@layout/heads_up_status_bar_layout" />
            <com.android.systemui.statusbar.views.LimitedSizeFrameLayout
                android:layout_gravity="center_vertical"
                android:id="@id/prompt_container"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/status_bar_icon_height"
                app:MiuiMaxWidth="@dimen/status_bar_prompt_max_width" />
            <ViewStub
                android:id="@id/operator_name_stub"
                android:layout="@layout/operator_name"
                android:layout_width="wrap_content"
                android:layout_height="match_parent" />
            <com.android.systemui.statusbar.views.MiuiClock
                android:textAppearance="@style/TextAppearance.StatusBar.Clock"
                android:gravity="center|start"
                android:id="@id/clock"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:singleLine="true"
                android:layout_marginStart="@dimen/status_bar_padding_extra_start"
                android:layout_marginEnd="@dimen/status_bar_clock_margin_end"
                app:MiuiAmPmStyle="gone"
                app:MiuiClockMode="time" />
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center|start"
                android:orientation="horizontal"
                android:background="@drawable/Background3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:layout_marginRight="0dp"
                android:layout_marginBottom="0dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/Background4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextClock
                        android:textSize="10dp"
                        android:textStyle="bold"
                        android:textColor="#FFFF0000"
                        android:gravity="center|start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-2dp"
                        android:format12Hour="hh"
                        android:format24Hour="HH" />
                    <TextClock
                        android:textSize="10dp"
                        android:textStyle="bold"
                        android:textColor="#EE000000"
                        android:gravity="center|start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-4dp"
                        android:format12Hour="mm"
                        android:format24Hour="mm" />
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="3dp"
                    android:layout_marginTop="0dp">
                    <TextClock
                        android:textSize="10dp"
                        android:textStyle="bold"
                        android:textColor="@android:color/system_accent1_800"
                        android:layout_gravity="left"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-1dp"
                        android:maxEms="6"
                        android:singleLine="true"
                        android:format12Hour=" EEEE"
                        android:format24Hour=" EEEE" />
                    <TextClock
                        android:textSize="8.500001dp"
                        android:textStyle="bold"
                        android:textColor="@android:color/system_accent1_800"
                        android:layout_gravity="left"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-4dp"
                        android:format12Hour="dd/MM/yyyy"
                        android:format24Hour="dd/MM/yyyy" />
                </LinearLayout>
            </LinearLayout>
            <ViewStub
                android:id="@id/pad_clock"
                android:layout="@layout/pad_clock"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/status_bar_padding_extra_start"
                android:layout_marginEnd="@dimen/status_bar_clock_margin_end" />
            <com.android.systemui.statusbar.AlphaOptimizedFrameLayout
                android:orientation="horizontal"
                android:id="@id/notification_icon_area"
                android:visibility="gone"
                android:clipChildren="false"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.0" />
        </LinearLayout>
        <android.widget.Space
            android:gravity="center"
            android:id="@id/cutout_space_view"
            android:layout_width="0dp"
            android:layout_height="match_parent" />
        <com.android.systemui.statusbar.views.MiuiNotificationStatusContainer
            android:id="@id/system_icon_area"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.android.systemui.statusbar.AlphaOptimizedFrameLayout
                android:id="@id/fullscreen_notification_icon_area"
                android:clipChildren="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
            <com.android.systemui.statusbar.phone.userswitcher.StatusBarUserSwitcherContainer
                android:orientation="horizontal"
                android:id="@id/user_switcher_container"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="0dp">
                <ImageView
                    android:id="@id/current_user_avatar"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerInside" />
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Clock"
                    android:id="@id/current_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </com.android.systemui.statusbar.phone.userswitcher.StatusBarUserSwitcherContainer>
            <include
                android:id="@id/system_icons"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/status_bar_padding_start"
                layout="@layout/system_icons" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/privacy_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="2dp" />
        </com.android.systemui.statusbar.views.MiuiNotificationStatusContainer>
        <FrameLayout
            android:id="@id/status_bar_start_side_content"
            android:visibility="gone"
            android:clipChildren="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <FrameLayout
            android:id="@id/status_bar_end_side_content"
            android:visibility="gone"
            android:clipChildren="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/focused_parent"
        android:paddingTop="@dimen/status_bar_padding_top"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:paddingStart="@dimen/status_bar_padding_start"
        android:paddingEnd="@dimen/status_bar_padding_end">
        <View
            android:id="@id/focused_notifi_start"
            android:background="@color/transparent"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="@dimen/status_bar_padding_extra_start" />
        <com.android.systemui.statusbar.phone.DividerLine
            android:layout_gravity="center_vertical"
            android:id="@id/view_line"
            android:visibility="gone"
            android:layout_width="@dimen/line_width"
            android:layout_height="@dimen/line_height"
            android:layout_marginStart="@dimen/status_bar_notification_padding_end" />
        <com.android.systemui.statusbar.phone.FocusedNotifPromptView
            android:gravity="center_vertical"
            android:layout_gravity="center|start"
            android:orientation="horizontal"
            android:id="@id/focused_notif_view"
            android:visibility="gone"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:importantForAccessibility="no"
            android:paddingStart="@dimen/focused_notif_view_padding_start">
            <com.android.systemui.statusbar.phone.FocusedNotifPromptImageView
                android:id="@id/focused_notif_icon"
                android:layout_width="@dimen/focused_notif_icon_size"
                android:layout_height="@dimen/focused_notif_icon_size"
                android:scaleType="centerInside" />
            <FrameLayout
                android:id="@id/focused_notif_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/focused_notif_content_start">
                <com.android.systemui.statusbar.widget.FocusedTextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Clock"
                    android:ellipsize="marquee"
                    android:id="@id/focused_notif_content_text"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:marqueeRepeatLimit="1"
                    android:fontFamily="MiSans-normal"
                    android:paddingEnd="8dp" />
                <com.android.systemui.statusbar.views.LimitedSizeFrameLayout
                    android:id="@id/focused_notif_content_remote"
                    android:visibility="gone"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:MiuiMaxWidth="@dimen/status_bar_prompt_max_width" />
            </FrameLayout>
        </com.android.systemui.statusbar.phone.FocusedNotifPromptView>
    </LinearLayout>
</com.android.systemui.statusbar.phone.MiuiPhoneStatusBarView>
