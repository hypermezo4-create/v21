<?xml version="1.0" encoding="utf-8"?>
<!-- This is a modified version of AXMLPrinter2(By Google) library. Check out how many changes are made at https://github.com/developer-krushna/AXMLPrinter by (@developer-krushna) -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?android:attr/colorControlHighlight">
    <item
        android:id="@android:id/mask">
        <shape>
            <gradient
                android:startColor="#ff000000"
                android:endColor="#ff000000" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item
        android:id="@android:id/background">
        <shape
            android:tint="@android:color/system_accent1_200"
            android:shape="rectangle">
            <padding
                android:left="2dp"
                android:top="1dp"
                android:right="2dp"
                android:bottom="1dp" />
            <corners
                android:topLeftRadius="8dp"
                android:topRightRadius="20dp"
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="8dp" />
        </shape>
    </item>
</ripple>
